NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/express_prisma_db?schema=public
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=15m
CORS_ORIGIN=http://localhost:3000
LOG_FORMAT=dev
BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SWAGGER_ENABLED=true
